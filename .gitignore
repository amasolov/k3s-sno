!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Ansible Galaxy collections/roles (installed locally)
ansible/collections/
ansible/roles/

# Temporary files
*.tmp
*.bak
