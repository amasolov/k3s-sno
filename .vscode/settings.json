{
  "files.associations": {
    "*.sops.yaml": "yaml",
    "*.sops.yml": "yaml"
  },
  "files.exclude": {
    "**/.task": true,
    "**/__pycache__": true
  },
  "yaml.schemas": {
    "kubernetes": [
      "kubernetes/**/*.yaml",
      "!kubernetes/**/kustomization.yaml"
    ]
  },
  "yaml.customTags": [
    "!secret",
    "!include"
  ],
  "editor.formatOnSave": false,
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "keep"
  },
  "[python]": {
    "editor.tabSize": 4
  },
  "sops.binPath": "sops",
  "sops.defaults.ageKeyFile": "age.key"
}
