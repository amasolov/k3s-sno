{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":disableRateLimiting",
    ":semanticCommits",
    ":automergeBranch"
  ],
  "flux": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process k3s version in Ansible playbook",
      "managerFilePatterns": [
        "/(^|/)ansible/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "k3s_version:\\s*(?<currentValue>v[\\d.]+\\+k3s\\d+)"
      ],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Process Squest version in GitHub Actions workflow",
      "managerFilePatterns": [
        "/(^|/).github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=HewlettPackard/squest\\n\\s+default:\\s*\"(?<currentValue>v[\\d.]+)\""
      ],
      "depNameTemplate": "HewlettPackard/squest",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Group Flux updates",
      "groupName": "Flux",
      "matchPackageNames": [
        "/flux/"
      ]
    },
    {
      "description": "Group External Secrets updates",
      "groupName": "External Secrets",
      "matchPackageNames": [
        "/external-secrets/"
      ]
    },
    {
      "description": "Group Squest-related updates",
      "groupName": "Squest",
      "matchPackageNames": [
        "HewlettPackard/squest",
        "ghcr.io/amasolov/squest"
      ]
    }
  ]
}
